{
  "name": "@yusufolosun/ahhbit-tracker-sdk",
  "version": "2.0.0",
  "description": "TypeScript SDK for the AhhbitTracker smart contracts on Stacks blockchain — habit tracking, accountability groups, streak rewards, typed transaction builders, read-only queries, and developer utilities.",
  "author": "Yusufolosun",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Yusufolosun/ahhbit-tracker-sdk.git"
  },
  "homepage": "https://github.com/Yusufolosun/ahhbit-tracker-sdk",
  "bugs": {
    "url": "https://github.com/Yusufolosun/ahhbit-tracker-sdk/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/Yusufolosun"
  },
  "keywords": [
    "stacks",
    "stx",
    "clarity",
    "blockchain",
    "smart-contract",
    "sdk",
    "habit-tracker-v3",
    "accountability",
    "streak-rewards",
    "dapp",
    "web3",
    "ahhbittracker",
    "crypto",
    "cryptocurrency",
    "bitcoin",
    "btc"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@stacks/network": ">=6.0.0",
    "@stacks/transactions": ">=6.0.0"
  },
  "devDependencies": {
    "@stacks/network": "^7.3.1",
    "@stacks/transactions": "^7.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  }
}
